# AIと一緒に描くマインドマップ — 環境変数 (実値は .env.local / デプロイ先 env に)
# 詳細取得手順: docs/PREREQUISITES.md
DATABASE_URL=postgres://user:pass@host/db
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
OPENAI_API_KEY=sk-xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# 自前署名 guest JWT の secret (§1.7、openssl rand -hex 32 で生成、本番のみ)
GUEST_TOKEN_SECRET=replace-with-openssl-rand-hex-32
# Sentry: フロント用 (公開 DSN, VITE_ prefix)。未設定なら監視は dormant (no-key safe)
VITE_SENTRY_DSN=
SENTRY_DSN=
# §4.6.2 コスト単価 (公開情報、最新 pricing 要確認)
COST_OPENAI_GPT4O_MINI_PER_1K_INPUT_TOKENS=0.00015
COST_OPENAI_GPT4O_MINI_PER_1K_OUTPUT_TOKENS=0.0006
# feedback-hub (任意)
FEEDBACK_HUB_URL=
